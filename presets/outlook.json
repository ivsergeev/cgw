    {
      "Id": "00000000-0000-0000-0006-000000000002",
      "Name": "outlook_messages",
      "Description": "List messages from a folder (default Inbox)",
      "GroupId": "outlook",
      "Url": "https://graph.microsoft.com/v1.0/me/mailFolders/{folder}/messages",
      "HttpMethod": "GET",
      "Parameters": [
        { "Name": "folder", "Description": "Folder: inbox, sentitems, drafts, deleteditems, junkemail, archive", "Type": "String", "Required": true },
        { "Name": "$top", "Description": "Message count (default 10, max 50)", "Type": "Integer", "Required": false },
        { "Name": "$skip", "Description": "Pagination offset", "Type": "Integer", "Required": false },
        { "Name": "$select", "Description": "Comma-separated fields (e.g. subject,from,receivedDateTime)", "Type": "String", "Required": false },
        { "Name": "$filter", "Description": "OData filter (e.g. isRead eq false)", "Type": "String", "Required": false },
        { "Name": "$orderby", "Description": "Sort order (e.g. receivedDateTime desc)", "Type": "String", "Required": false }
      ],
      "Headers": {},
      "BodyTemplate": "",
      "FetchOrigin": "https://outlook.office.com",
      "ResponseFilter": "",
      "CacheEnabled": false,
      "CacheTtlSeconds": 60
    },
    {
      "Id": "00000000-0000-0000-0006-000000000003",
      "Name": "outlook_message",
      "Description": "Single message by ID (including body)",
      "GroupId": "outlook",
      "Url": "https://graph.microsoft.com/v1.0/me/messages/{message_id}",
      "HttpMethod": "GET",
      "Parameters": [
        { "Name": "message_id", "Description": "Message ID", "Type": "String", "Required": true },
        { "Name": "$select", "Description": "Fields (e.g. subject,body,from,toRecipients,receivedDateTime)", "Type": "String", "Required": false }
      ],
      "Headers": { "Prefer": "outlook.body-content-type=\"text\"" },
      "BodyTemplate": "",
      "FetchOrigin": "https://outlook.office.com",
      "ResponseFilter": "",
      "CacheEnabled": false,
      "CacheTtlSeconds": 60
    },
