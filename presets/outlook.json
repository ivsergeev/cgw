      "GroupId": "outlook",
      "Url": "https://graph.microsoft.com/v1.0/me/messages/{message_id}",
      "HttpMethod": "GET",
      "Parameters": [
        { "Name": "message_id", "Description": "ID письма", "Type": "String", "Required": true },
        { "Name": "$select", "Description": "Поля (напр. subject,body,from,toRecipients,receivedDateTime)", "Type": "String", "Required": false }
      ],
