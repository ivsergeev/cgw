    {
      "Id": "00000000-0000-0000-0006-000000000002",
      "Name": "outlook_messages",
      "Description": "Список писем из папки (по умолчанию Входящие)",
      "GroupId": "outlook",
      "Url": "https://graph.microsoft.com/v1.0/me/mailFolders/{folder}/messages",
      "HttpMethod": "GET",
      "Parameters": [
        { "Name": "folder", "Description": "Папка: inbox, sentitems, drafts, deleteditems, junkemail, archive", "Type": "String", "Required": true },
        { "Name": "$top", "Description": "Кол-во писем (по умолчанию 10, макс. 50)", "Type": "Integer", "Required": false },
        { "Name": "$skip", "Description": "Смещение для пагинации", "Type": "Integer", "Required": false },
        { "Name": "$select", "Description": "Поля через запятую (напр. subject,from,receivedDateTime)", "Type": "String", "Required": false },
        { "Name": "$filter", "Description": "OData фильтр (напр. isRead eq false)", "Type": "String", "Required": false },
        { "Name": "$orderby", "Description": "Сортировка (напр. receivedDateTime desc)", "Type": "String", "Required": false }
      ],
      "Headers": {},
      "BodyTemplate": "",
      "FetchOrigin": "https://outlook.office.com",
      "ResponseFilter": "",
      "CacheEnabled": false,
      "CacheTtlSeconds": 60
    },
    {
